---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const all = await getCollection("pages");
const entry = all.find((p) => p.data.isHome && p.data.draft !== true);
if (!entry) throw new Error("No homepage found. Set `isHome: true` in one Markdown file in src/content/pages/");

const { Content, headings } = await entry.render();
const title = entry.data.title ?? "The Nida Institute";
const description = entry.data.description ?? "";
---

<BaseLayout title={title} description={description} activePath="/" headings={headings}>
  <Content />
</BaseLayout>
